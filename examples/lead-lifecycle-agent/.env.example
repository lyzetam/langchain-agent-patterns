# Copy to .env and fill in.
ANTHROPIC_API_KEY=

# Optional: use a different provider:model (default: anthropic:claude-sonnet-4-6)
# DEEP_AGENT_MODEL=openai:gpt-5

# Optional: persistent long-term memory via Supabase / Postgres.
# Leave unset to use in-memory storage. Requires the `postgres` extra:
#   pip install -e ".[postgres]"
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
